#!/usr/bin/env bash
# SessionStart hook for long-task-agent plugin
# Injects the using-long-task bootstrap skill into every session.

set -euo pipefail

# Determine plugin root directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Read using-long-task bootstrap skill
using_long_task_content=$(cat "${PLUGIN_ROOT}/skills/using-long-task/SKILL.md" 2>&1 \
  || echo "Error reading using-long-task skill")

# Detect project phase and build status hint
status_hint=""
if [ -f "increment-request.json" ]; then
    # Phase 1.5: Increment — incremental requirements development
    status_hint="\\n\\nIncrement request found. Phase: Increment."
elif [ -f "feature-list.json" ]; then
    # Count feature progress (exclude deprecated features)
    total=$(python3 -c "import json; d=json.load(open('feature-list.json')); print(len([f for f in d.get('features',[]) if not f.get('deprecated',False)]))" 2>/dev/null || echo "?")
    passing=$(python3 -c "import json; d=json.load(open('feature-list.json')); print(sum(1 for f in d.get('features',[]) if f.get('status')=='passing' and not f.get('deprecated',False)))" 2>/dev/null || echo "?")
    deprecated=$(python3 -c "import json; d=json.load(open('feature-list.json')); print(sum(1 for f in d.get('features',[]) if f.get('deprecated',False)))" 2>/dev/null || echo "0")
    if [ "$total" != "?" ] && [ "$passing" != "?" ] && [ "$total" = "$passing" ] && [ "$total" != "0" ]; then
        # Phase 3: System Testing — all active features passing
        dep_note=""
        [ "$deprecated" != "0" ] && dep_note=" (${deprecated} deprecated)"
        status_hint="\\n\\nProject status: ${passing}/${total} active features passing (ALL)${dep_note}. Phase: System Testing."
    else
        # Phase 2: Worker — some active features still failing
        dep_note=""
        [ "$deprecated" != "0" ] && dep_note=" (${deprecated} deprecated)"
        status_hint="\\n\\nProject status: ${passing}/${total} active features passing${dep_note}. Phase: Worker."
    fi
elif compgen -G "docs/plans/*-ats.md" > /dev/null 2>&1; then
    status_hint="\\n\\nATS doc found. Phase: Initializer."
elif compgen -G "docs/plans/*-design.md" > /dev/null 2>&1; then
    status_hint="\\n\\nDesign doc found. Phase: ATS (Acceptance Test Strategy)."
elif compgen -G "docs/plans/*-ucd.md" > /dev/null 2>&1; then
    status_hint="\\n\\nUCD style guide found. Phase: Design."
elif compgen -G "docs/plans/*-srs.md" > /dev/null 2>&1; then
    status_hint="\\n\\nSRS doc found. Phase: UCD Style Guide."
else
    status_hint="\\n\\nNo SRS, design, or feature-list.json found. Phase: Requirements."
fi

# ── Render SKILL.md.template → .long-task-bindings/ (enterprise MCP support) ──
# Renders only when tool-bindings.json exists AND Jinja2 is available.
# Output goes to the project-local .long-task-bindings/ directory — NOT to the
# plugin directory — so concurrent sessions on different projects don't race.
# On failure, warn to stderr but never abort the session.
# NOTE: Jinja2 is NOT auto-installed here. Use check_jinja2.py to detect and
# guide the user through installation (same pattern as check_devtools.py).
RENDER_SCRIPT="${PLUGIN_ROOT}/scripts/apply_tool_bindings.py"
if [ -f "$RENDER_SCRIPT" ] && [ -f "tool-bindings.json" ]; then
    if python3 -c "import jinja2" 2>/dev/null; then
        python3 "$RENDER_SCRIPT" "tool-bindings.json" \
            --output-dir ".long-task-bindings" --quiet 2>/tmp/lt-render-warn.txt \
            || echo "[long-task] Warning: tool binding render failed. See /tmp/lt-render-warn.txt" >&2
    else
        echo "[long-task] Warning: jinja2 not installed — enterprise template rendering skipped. Run: python scripts/check_jinja2.py" >&2
    fi
fi

# ── Copy init_project.py to project scripts dir ──────────────────────────────
# Ensures that models following the SKILL.md instruction
# `python scripts/init_project.py …` can find the script in the target project.
# The companion hint file tells the copied script where the plugin root is so it
# can locate and copy the helper scripts (validate_features.py etc.) correctly.
INIT_SCRIPT_SRC="${PLUGIN_ROOT}/skills/long-task-init/scripts/init_project.py"
if [ -f "$INIT_SCRIPT_SRC" ]; then
    mkdir -p "scripts"
    cp "$INIT_SCRIPT_SRC" "scripts/init_project.py"
    # Git Bash on Windows returns POSIX-style paths from `pwd`: /c/Users/...
    # Python on Windows cannot resolve these with os.path.isdir(), so convert
    # /c/Users/... → C:/Users/... before writing the hint file.
    PLUGIN_ROOT_HINT="${PLUGIN_ROOT}"
    if [[ "${PLUGIN_ROOT}" =~ ^/([a-zA-Z])/(.+) ]]; then
        PLUGIN_ROOT_HINT="${BASH_REMATCH[1]^^}:/${BASH_REMATCH[2]}"
    fi
    printf '%s' "${PLUGIN_ROOT_HINT}" > "scripts/.long-task-plugin-root"
fi

# Escape string for JSON embedding using bash parameter substitution.
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

content_escaped=$(escape_for_json "$using_long_task_content")
status_escaped=$(escape_for_json "$status_hint")
session_context="<EXTREMELY_IMPORTANT>\nYou are in a long-task project.\n\n**Below is your 'long-task:using-long-task' skill - your project router. For all other skills, use the Skill tool:**\n\n${content_escaped}\n${status_escaped}\n</EXTREMELY_IMPORTANT>"

# Output context injection as JSON.
# Keep both shapes for compatibility:
# - Cursor hooks expect additional_context.
# - Claude hooks expect hookSpecificOutput.additionalContext.
cat <<EOF
{
  "additional_context": "${session_context}",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${session_context}"
  }
}
EOF

exit 0
