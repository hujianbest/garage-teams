#!/bin/bash
###############################################################################
# chrome-mcp-setup — upsert top-level mcpServers.chrome-devtools in ~/.claude.json
# All diagnostic output goes to stderr; stdout is kept empty (hook-safe).
# Uses only bash builtins + awk/grep (no python dependency).
###############################################################################

set -euo pipefail

CLAUDE_CONFIG="$HOME/.claude.json"

# ── Desired chrome-devtools block (2-space top-level indent) ──
CD_BLOCK='    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--isolated=true",
        "--no-usage-statistics"
      ]
    }'

# ── Helper: check if a line is a top-level key (2-space indent) ──
# In pretty-printed JSON, top-level keys sit at exactly 2 spaces.
# Nested project mcpServers sit at 6+ spaces.

# ═══════════════════════════════════════════════════════════════════
# Case 1: file missing or empty → create from scratch
# ═══════════════════════════════════════════════════════════════════
if [ ! -f "$CLAUDE_CONFIG" ] || [ ! -s "$CLAUDE_CONFIG" ]; then
    cat > "$CLAUDE_CONFIG" << 'TEMPLATE'
{
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--isolated=true",
        "--no-usage-statistics"
      ]
    }
  }
}
TEMPLATE
    echo "[chrome-mcp-setup] created $CLAUDE_CONFIG" >&2
    exit 0
fi

ORIGINAL=$(cat "$CLAUDE_CONFIG")

# Only match TOP-LEVEL mcpServers (2-space indent, not deeper)
has_top_mcp=0
echo "$ORIGINAL" | grep -q '^  "mcpServers"' && has_top_mcp=1

# Check for chrome-devtools INSIDE top-level mcpServers only.
# Strategy: extract the top-level mcpServers block and grep within it.
has_top_chrome=0
if [ "$has_top_mcp" -eq 1 ]; then
    # Check for chrome-devtools at 4-space indent (inside top-level mcpServers)
    echo "$ORIGINAL" | grep -q '^    "chrome-devtools"' && has_top_chrome=1
fi

# ═══════════════════════════════════════════════════════════════════
# Case 2: no top-level mcpServers → insert before closing }
# ═══════════════════════════════════════════════════════════════════
if [ "$has_top_mcp" -eq 0 ]; then
    # Insert mcpServers block before the very last line (which is the closing })
    # The last line of a pretty-printed JSON is always "}" at column 0.
    result=$(echo "$ORIGINAL" | awk -v block="$CD_BLOCK" '
    {
        saved[NR] = $0
    }
    END {
        # Find last line with just "}"
        last = NR
        for (i = NR; i >= 1; i--) {
            s = saved[i]
            gsub(/^[[:space:]]+|[[:space:]]+$/, "", s)
            if (s == "}") { last = i; break }
        }
        # Ensure comma on previous non-empty line
        for (j = last - 1; j >= 1; j--) {
            s = saved[j]
            gsub(/^[[:space:]]+|[[:space:]]+$/, "", s)
            if (s != "") {
                ch = substr(s, length(s), 1)
                if (ch != "," && ch != "{" && ch != "[") {
                    saved[j] = saved[j] ","
                }
                break
            }
        }
        for (i = 1; i < last; i++) print saved[i]
        printf "  \"mcpServers\": {\n"
        printf "%s\n", block
        printf "  }\n"
        print saved[last]
    }')

    echo "$result" > "$CLAUDE_CONFIG"
    echo "[chrome-mcp-setup] added top-level mcpServers.chrome-devtools" >&2
    exit 0
fi

# ═══════════════════════════════════════════════════════════════════
# Case 3: top-level mcpServers exists but no chrome-devtools → insert
# ═══════════════════════════════════════════════════════════════════
if [ "$has_top_mcp" -eq 1 ] && [ "$has_top_chrome" -eq 0 ]; then
    result=$(echo "$ORIGINAL" | awk -v block="$CD_BLOCK" '
    {
        print $0
        # Match ONLY top-level mcpServers (2-space indent)
        if (!done && /^  "mcpServers"/) {
            if (index($0, "{") > 0) {
                if ((getline nextline) > 0) {
                    tmp = nextline; gsub(/^[[:space:]]+/, "", tmp)
                    if (substr(tmp, 1, 1) == "}") {
                        printf "%s\n", block
                    } else {
                        printf "%s,\n", block
                    }
                    print nextline
                } else {
                    printf "%s\n", block
                }
                done = 1
            }
        }
        # Handle case where { is on next line
        if (!done && found_top_mcp && index($0, "{") > 0) {
            if ((getline nextline) > 0) {
                tmp = nextline; gsub(/^[[:space:]]+/, "", tmp)
                if (substr(tmp, 1, 1) == "}") {
                    printf "%s\n", block
                } else {
                    printf "%s,\n", block
                }
                print nextline
            } else {
                printf "%s\n", block
            }
            done = 1
        }
        found_top_mcp = /^  "mcpServers"/
    }')

    echo "$result" > "$CLAUDE_CONFIG"
    echo "[chrome-mcp-setup] inserted chrome-devtools into top-level mcpServers" >&2
    exit 0
fi

# ═══════════════════════════════════════════════════════════════════
# Case 4: chrome-devtools exists in top-level mcpServers → replace
# ═══════════════════════════════════════════════════════════════════
result=$(echo "$ORIGINAL" | awk -v block="$CD_BLOCK" '
BEGIN { skip = 0; depth = 0; inserted = 0; in_top_mcp = 0; top_mcp_depth = 0 }
{
    # Track if we are inside top-level mcpServers (2-space indent)
    if (/^  "mcpServers"/) {
        in_top_mcp = 1
        top_mcp_depth = 0
        for (i = 1; i <= length($0); i++) {
            c = substr($0, i, 1)
            if (c == "{") top_mcp_depth++
            if (c == "}") top_mcp_depth--
        }
    } else if (in_top_mcp) {
        for (i = 1; i <= length($0); i++) {
            c = substr($0, i, 1)
            if (c == "{") top_mcp_depth++
            if (c == "}") top_mcp_depth--
        }
        if (top_mcp_depth <= 0) in_top_mcp = 0
    }

    # Only replace chrome-devtools if inside top-level mcpServers
    if (!skip && in_top_mcp && /^    "chrome-devtools"/) {
        skip = 1
        depth = 0
        for (i = 1; i <= length($0); i++) {
            c = substr($0, i, 1)
            if (c == "{") depth++
            if (c == "}") depth--
        }
        if (depth <= 0) {
            skip = 0
            s = $0; gsub(/[[:space:]]+$/, "", s)
            comma = (substr(s, length(s), 1) == ",") ? "," : ""
            if (!inserted) { printf "%s%s\n", block, comma; inserted = 1 }
        }
        next
    }
    if (skip) {
        for (i = 1; i <= length($0); i++) {
            c = substr($0, i, 1)
            if (c == "{") depth++
            if (c == "}") depth--
        }
        if (depth <= 0) {
            skip = 0
            s = $0; gsub(/[[:space:]]+$/, "", s)
            comma = (substr(s, length(s), 1) == ",") ? "," : ""
            if (!inserted) { printf "%s%s\n", block, comma; inserted = 1 }
        }
        next
    }
    print $0
}')

echo "$result" > "$CLAUDE_CONFIG"
echo "[chrome-mcp-setup] replaced chrome-devtools in top-level mcpServers" >&2
exit 0
